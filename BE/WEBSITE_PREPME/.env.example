# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in real values
# NEVER commit the real .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_NAME=prepme_db
DB_PORT=5432
DB_ROOT_PASSWORD=POSTGRES_PASSWORD
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=StrongRedisPass@2026!

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be Base64 encoded, at least 256 bits (32 chars raw → encode to Base64)
# Generate: openssl rand -base64 64
JWT_SECRET=cHJlcG1lX3N1cGVyX3NlY3JldF9rZXlfZm9yX2p3dF90b2tlbl9nZW5lcmF0aW9uXzIwMjY=
JWT_ACCESS_EXPIRATION=2592000000

# ─── Mail (Gmail App Password) ────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=dilyyimrn
CLOUDINARY_API_KEY=622376695845593
CLOUDINARY_API_SECRET=jmkTaFT6ZXoxqhEZ_slTs2y2XQs
CLOUDINARY_FOLDER=prepme

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Google OAuth2 ─────────────────────────────────────────────────────────────────
# B1: Vào https://console.cloud.google.com
# B2: APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
# B3: Application type: Web application
# B4: Authorized redirect URIs: http://localhost:3000 (frontend URL)
# B5: Copy Client ID vào đây
GOOGLE_CLIENT_ID=1007612157259-vvqh58i2t6s3nqignos3bt42q80qfhgj.apps.googleusercontent.com
